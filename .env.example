# أصل الخادم فقط (مثلاً http://localhost:5000)، بدون ‎/api‎ في النهاية — وجودها قد يولِّد ‎404‎ على ‎/api/api/mv/…‎
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# هدف الـ proxy (Next → Nest). لا تستخدم نهاية ‎/api‎
BACKEND_URL=http://localhost:5000

# اختياري (Docker / DigitalOcean): عنوان Nest داخل الشبكة الخاصة حتى لا يستخدم Next ‎127.0.0.1‎ (ECONNREFUSED).
# مثال: MV_INTERNAL_API_ORIGIN=http://sparkvision-backend:5000
MV_INTERNAL_API_ORIGIN=

# التطوير: تسخين المسارات بعد فتح المنفذ (TCP فقط، بدون GET / مكرر). للإيقاف: FRONTEND_DEV_WARM_ROUTES=false
# اختياري: FRONTEND_DEV_WARM_BATCH=5 و FRONTEND_DEV_WARM_BATCH_GAP_MS=80 (زيادة الدفعة تسرّع التسخين وقد تثقل الجهاز)

# تتبع التنقّل/التفاعل داخل الموقع (نبض، تمرير، page_view…). الافتراضي معطّل. للتشغيل: NEXT_PUBLIC_SV_BEHAVIOR_TRACKING=1
