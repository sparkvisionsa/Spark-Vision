# اختياري: للـ fetch من جانب السيرفر (SSR) فقط؛ المتصفح يستخدم /api/* ويتم التوجيه عبر next.config
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# هدف إعادة التوجيه (Next → Nest). يُفضّل ضبطه ليتطابق مع البورت الذي يعمل عليه الباك اند
BACKEND_URL=http://localhost:5000

# التطوير: تسخين المسارات بعد فتح المنفذ (TCP فقط، بدون GET / مكرر). للإيقاف: FRONTEND_DEV_WARM_ROUTES=false
# اختياري: FRONTEND_DEV_WARM_BATCH=5 و FRONTEND_DEV_WARM_BATCH_GAP_MS=80 (زيادة الدفعة تسرّع التسخين وقد تثقل الجهاز)
